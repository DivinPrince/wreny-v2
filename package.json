{
  "name": "1000hills",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:generate": "sst shell -- bun run --cwd packages/core db:generate",
    "db:migrate": "sst shell -- bun run --cwd packages/core db:migrate",
    "db:push": "sst shell -- bun run --cwd packages/core db:push",
    "db:studio": "sst shell -- bun run --cwd packages/core db:studio",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "sst:dev": "sst dev",
    "sst:deploy": "sst deploy",
    "sst:remove": "sst remove",
    "sst:shell": "sst shell"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint-plugin-turbo": "^2.7.1",
    "oxlint": "^1.0.0",
    "prettier": "^3.7.4",
    "sst": "^4.2.2",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
