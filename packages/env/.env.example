# ─── Server Environment (API, CLI, Core) ─────────────────────────────────────
# Copy to packages/core/.env or your API app root

# Database (PostgreSQL) – REQUIRED for API
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional: Drizzle query logging
DRIZZLE_LOG=false

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# ─── Auth (Better Auth) ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-super-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# URLs (CORS, redirects)
FRONTEND_URL=http://localhost:5000
ADMIN_URL=http://localhost:5002
API_URL=http://localhost:3000
API_PORT=5001

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM="Your App <noreply@example.com>"

# ─── Billing (Polar) ────────────────────────────────────────────────────────
# https://polar.sh/docs — Settings → Developers (access token); webhook endpoint secret
# POLAR_ACCESS_TOKEN=polar_oat_xxxxx
# POLAR_WEBHOOK_SECRET=whsec_xxxxx
# PAYMENT_PROVIDER=polar

# ─── Storage (AWS S3 or GCS) ────────────────────────────────────────────────
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=my-bucket

# Or for Google Cloud Storage:
# GCS_PROJECT_ID=my-project
# GCS_BUCKET_NAME=my-bucket
# GCS_MAKE_PUBLIC=true
# GCS_SERVICE_ACCOUNT_KEY_BASE64=<base64-encoded-json-key>

# ─── AI / Integrations ──────────────────────────────────────────────────────
# GOOGLE_GENERATIVE_AI_API_KEY=xxxxx
# FIRECRAWL_API_KEY=fc-xxxxx
# LinkedIn profile import — Relevance Stack (see linkedin-profile-import.ts for trigger URL)
# RELEVANCE_LINKEDIN_IMPORT_API_KEY=<YOUR_API_KEY from Relevance>

# ─── POS API ────────────────────────────────────────────────────────────────
# POS_API_URL=http://localhost:8080
# POS_API_TOKEN=xxxxx

# ─── Observability ──────────────────────────────────────────────────────────
# AXIOM_API_TOKEN=xxxxx
# AXIOM_DATASET=my-app
# OTEL_SERVICE_NAME=my-api
