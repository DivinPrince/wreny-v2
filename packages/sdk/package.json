{
  "name": "@repo/sdk",
  "version": "0.1.0",
  "description": "Type-safe SDK for 1000hills API",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    }
  },
  "scripts": {
    "lint": "oxlint --max-warnings 0",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/core": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@types/react": "^19.0.0",
    "oxlint": "^1.0.0",
    "tsup": "^8.0.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@tanstack/react-query": "^5.90.21",
    "ai": "^6.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^4.0.0"
  }
}
