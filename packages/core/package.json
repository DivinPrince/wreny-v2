{
  "name": "@repo/core",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": {
      "types": "./src/*/index.ts",
      "default": "./src/*/index.ts"
    },
    "./drizzle": {
      "types": "./src/drizzle/index.ts",
      "default": "./src/drizzle/index.ts"
    },
    "./error": {
      "types": "./src/error.ts",
      "default": "./src/error.ts"
    },
    "./actor": {
      "types": "./src/actor.ts",
      "default": "./src/actor.ts"
    },
    "./context": {
      "types": "./src/context.ts",
      "default": "./src/context.ts"
    },
    "./event": {
      "types": "./src/event.ts",
      "default": "./src/event.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./payment": {
      "types": "./src/payment/index.ts",
      "default": "./src/payment/index.ts"
    }
  },
  "scripts": {
    "lint": "oxlint --max-warnings 0 --threads 1",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/cli/seed.ts",
    "db:seed:clean": "bun run src/cli/seed.ts --clean",
    "db:seed:sample-products": "bun run src/cli/seed-sample-products.ts",
    "typecheck": "tsc --noEmit",
    "create-admin": "bun run src/cli/create-admin.ts",
    "verify-stock": "bun run src/cli/verify-stock-consistency.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.18",
    "@aws-sdk/client-eventbridge": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@better-auth/infra": "^0.1.8",
    "@mendable/firecrawl-js": "^4.12.0",
    "ai": "^6.0.64",
    "better-auth": "^1.5.4",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1",
    "resend": "^4.0.1",
    "sst": "^4.2.2",
    "stripe": "^20.3.1",
    "ulid": "^2.3.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "oxlint": "^1.0.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.2"
  }
}
