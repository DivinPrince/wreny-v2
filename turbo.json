{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD",
    "ADMIN_NAME",
    "DATABASE_URL",
    "NEXT_PUBLIC_API_URL",
    "VITE_API_URL",
    "FRONTEND_URL",
    "ADMIN_URL",
    "NODE_ENV",
    "BETTER_AUTH_URL",
    "API_URL",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "AWS_REGION",
    "S3_BUCKET_NAME",
    "SEED_ADMIN_EMAIL",
    "SEED_ADMIN_PASSWORD",
    "SEED_SHOPPER_EMAIL",
    "SEED_SHOPPER_PASSWORD",
    "DRIZZLE_LOG",
    "PAYMENT_PROVIDER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["API_URL", "VITE_API_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["API_URL", "VITE_API_URL"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "env": ["API_URL", "VITE_API_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["API_URL", "VITE_API_URL"]
    }
  }
}
